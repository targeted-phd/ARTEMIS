# RF Monitor — Environment Configuration
# Copy to .env and customize

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# GROBID
GROBID_URL=http://grobid:8070

# Ollama (host.docker.internal for native host Ollama w/ GPU)
OLLAMA_URL=http://host.docker.internal:11434

# Sentinel
SENTINEL_TARGETS=826,828,830,832,834,878
SENTINEL_DURATION=2592000
SENTINEL_IQ_BUDGET_MB=10000

# PDF source for KG pipeline
PDF_ROOT=/data/papers
